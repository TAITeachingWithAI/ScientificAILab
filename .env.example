# Scientific AI Laboratory - configuration
#
# Copy this file to ".env" (which is git-ignored) and fill in ONE provider.
# The whole app is reconfigured by editing these lines only.

# Which AI provider to use: gemini | groq | openai | ollama
LAB_PROVIDER=gemini

# Optional: override the model. Leave empty to use the provider's default.
LAB_MODEL=

# Where uploaded scenarios are stored: "local" (a data/ folder) or "s3".
STORE_BACKEND=local

# --- S3-compatible storage (only needed when STORE_BACKEND=s3) ---
# Works with Cloudflare R2, AWS S3, Backblaze B2, MinIO.
# Cloudflare R2 example:
#   S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
#   S3_REGION=auto
# AWS S3 example:
#   S3_ENDPOINT_URL=            (leave empty)
#   S3_REGION=eu-west-1
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_PREFIX=scenarios/
# Public base URL of the app, used to build the student share links.
# Locally this is http://localhost:8501; when deployed, set your public URL.
APP_BASE_URL=http://localhost:8501

# Optional: protect the Teacher view with a shared code so students can't open
# it (even by editing the URL) and read the answer. Empty = no gate.
TEACHER_ACCESS_CODE=

# --- API keys: you only need the one for the provider chosen above ---

# Google Gemini  (free tier available) -> https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq  (free tier available) -> https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI  (paid, usage-based) -> https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama runs locally and needs NO key. Just install Ollama, run a model
# (e.g. `ollama run llama3.1`), and set LAB_PROVIDER=ollama above.
